# ============================================================
# A2A Treasury Network — Agentic Commerce Framework
# AlgoBharat Hackathon — Problem 7
# Copy to .env and fill in your values
# ============================================================

# LLM
GROQ_API_KEY=your_groq_api_key_here

# Database (set by Docker Compose — do not change)
DATABASE_URL=postgresql+asyncpg://acf:acf@db:5432/acf
REDIS_URL=redis://redis:6379/0

# x402 Payment Protocol
X402_ENABLED=true
X402_SIMULATION_MODE=true          # true=simulated, false=LIVE Algorand testnet

# On-chain Audit Anchor
ANCHOR_ENABLED=true                # Anchors Merkle root to Algorand testnet

# Algorand — Required for LIVE mode (X402_SIMULATION_MODE=false)
ALGORAND_ALGOD_ADDRESS=https://testnet-api.algonode.cloud
ALGORAND_ALGOD_TOKEN=
ALGORAND_INDEXER_ADDRESS=https://testnet-idx.algonode.cloud
ALGORAND_NETWORK=testnet
BUYER_WALLET_MNEMONIC=             # 25-word mnemonic — buyer agent signs payments
BUYER_WALLET_ADDRESS=              # Buyer Algorand testnet address
SELLER_WALLET_MNEMONIC=            # Optional — seller mnemonic for escrow disputes
SELLER_WALLET_ADDRESS=             # Seller Algorand testnet address
X402_DEMO_AMOUNT_MICRO=10000       # Payment cap in microAlgos (10000 = 0.01 ALGO)

# Smart Contract Escrow (TreasuryEscrow)
ALGORAND_SIMULATION=true           # true=simulated SIM- tx_ids, false=LIVE smart contract
ALGORAND_ESCROW_CREATOR_MNEMONIC=  # 25-word mnemonic — platform deployer/arbitrator
ALGORAND_USDC_ASSET_ID=10458941    # USDC ASA on Algorand TestNet

# FX Engine
FX_PROVIDER=frankfurter
FX_SPREAD_BPS=25
FEMA_ODI_LIMIT_USD=250000

